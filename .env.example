DATABASE_URL="postgresql://user:password@localhost:5432/rewards_optimizer?schema=public"

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY="your_posthog_project_api_key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Cron Job Security
CRON_SECRET="your_secure_random_string_here"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="your_clerk_publishable_key"
CLERK_SECRET_KEY="your_clerk_secret_key"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/users"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/users"

# Stripe Payment Processing
STRIPE_SECRET_KEY="your_stripe_secret_key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="your_stripe_publishable_key"
STRIPE_WEBHOOK_SECRET="your_stripe_webhook_secret"

# Plaid Bank Integration (Optional - currently paused)
PLAID_CLIENT_ID="your_plaid_client_id"
PLAID_SECRET="your_plaid_secret"
PLAID_ENV="sandbox"

# Resend Email Service
RESEND_API_KEY="your_resend_api_key"

# Clerk Webhook Secret (for user.created events)
CLERK_WEBHOOK_SECRET="your_clerk_webhook_secret"

# Admin Access Control
# Comma-separated list of admin emails for admin panel and all admin operations
ADMIN_EMAILS="admin@example.com,admin2@example.com"

# Google Gemini API for AI-powered content generation (FREE)
GEMINI_API_KEY="your_gemini_api_key"

# Security and Encryption
TOKEN_ENCRYPTION_KEY="your_64_character_hex_string_for_token_encryption"
TOKEN_ENCRYPTION_KEY_VERSION="1"

# Sentry Error Monitoring (Optional)
SENTRY_DSN="your_sentry_dsn"
SENTRY_ORG="your_sentry_org"
SENTRY_PROJECT="your_sentry_project"

# Rate Limiting (Redis - Optional, uses in-memory if not provided)
REDIS_URL="redis://localhost:6379"
